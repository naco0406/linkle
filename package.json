{
  "name": "linkle",
  "version": "0.0.0",
  "private": true,
  "description": "Linkle — daily Wikipedia race game (Cloudflare + Vite monorepo)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:web": "pnpm --filter @linkle/web dev",
    "dev:admin": "pnpm --filter @linkle/admin dev",
    "dev:api": "pnpm --filter @linkle/api dev",
    "build": "pnpm -r --filter=./apps/* --filter=./packages/* build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm --filter @linkle/e2e test",
    "test:e2e:ui": "pnpm --filter @linkle/e2e test:ui",
    "harness": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:unit",
    "harness:full": "pnpm harness && pnpm build && pnpm test:e2e",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "lefthook": "^1.10.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
