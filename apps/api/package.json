{
  "name": "@linkle/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply linkle-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply linkle-db --remote",
    "db:create": "wrangler d1 create linkle-db",
    "db:seed:local": "wrangler d1 execute linkle-db --local --file ./src/db/seed.sql"
  },
  "dependencies": {
    "@linkle/shared": "workspace:*",
    "hono": "^4.6.15",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@linkle/tsconfig": "workspace:*",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "wrangler": "^3.101.0"
  }
}
